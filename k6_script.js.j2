import remote from 'k6/x/remotewrite';
import faker from 'k6/x/faker';
{% if mode == 'select' %}
import http from 'k6/http';
import { check } from 'k6';
{% else %}
import { check } from 'k6';
{% endif %}

const WRITE_URL  = __ENV.WRITE_URL  || '{{ write_url }}';
const SELECT_URL = __ENV.SELECT_URL || '{{ select_url }}';

export const options = {
  scenarios: {
{% if mode == 'select' %}
    up: {
      executor: 'externally-controlled',
      exec: 'query_up',
      vus: {{ vus }},
      maxVUs: {{ maxVUs }},
      duration: 0,
    },
    metric: {
      executor: 'externally-controlled',
      exec: 'query_metric',
      vus: {{ vus }},
      maxVUs: {{ maxVUs }},
      duration: 0,
    },
    aggregate: {
      executor: 'externally-controlled',
      exec: 'query_aggregate',
      vus: {{ vus }},
      maxVUs: {{ maxVUs }},
      duration: 0,
    },
{% else %}
    main: {
      executor: 'externally-controlled',
      vus: {{ vus }},
      maxVUs: {{ maxVUs }},
      duration: 0,
    },
{% endif %}
  },
  insecureSkipTLSVerify: true,
};

{% if mode == 'insert' %}
const client = new remote.Client({ url: WRITE_URL });

export default function () {
  const metricIdx = faker.numbers.intRange(0, {{ num_metrics - 1 }});
  const res = client.store([
    remote.Timeseries(
      {
        __name__: `{{ metric_name }}_${metricIdx}`,
        first_name: faker.person.firstName(),
        last_name: faker.person.lastName(),
{% for i in range(num_labels) %}
        label_{{ i }}: faker.person.firstName(),
{% endfor %}
      },
      [remote.Sample(faker.numbers.intRange(1, 10000), Date.now())],
    ),
  ]);
  check(res, { 'insert status is 2xx': (r) => r.status >= 200 && r.status < 300 });
}
{% else %}
function run_query(query) {
  const now = Date.now();
  // 10 minutes ago
  const start = Math.floor((now - 10 * 60 * 1000) / 1000);
  const end = Math.floor(now / 1000);
  const res = http.post(
    SELECT_URL,
    { query: query, start: start, end: end, step: '15s' },
    { responseType: 'none' },
  );
  check(res, { 'query status is 200': (r) => r.status === 200 });
}

export function query_up() {
  run_query(`{{ metric_name }}_0`);
}

export function query_metric() {
  const metricIdx = faker.numbers.intRange(0, {{ num_metrics - 1 }});
  run_query(`rate({{ metric_name }}_${metricIdx}[1m])`);
}

export function query_aggregate() {
  const metricIdx = faker.numbers.intRange(0, {{ num_metrics - 1 }});
  run_query(`sum by (last_name) (rate({{ metric_name }}_${metricIdx}[1m]))`);
}
{% endif %}
