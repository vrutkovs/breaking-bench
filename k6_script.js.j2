import remote from 'k6/x/remotewrite';
import faker from 'k6/x/faker';
{% if mode == 'select' %}
import http from 'k6/http';
import { check } from 'k6';
{% else %}
import { check } from 'k6';
{% endif %}

const WRITE_URL   = __ENV.WRITE_URL   || '{{ write_url }}';
const SELECT_URL  = __ENV.SELECT_URL  || '{{ select_url }}';
const METRICS_URL = __ENV.METRICS_URL || '{{ metrics_url }}';

export const options = {
  scenarios: {
{% if mode == 'select' %}
{% if fast_rps > 0 %}
    fast_queries: {
      executor: 'constant-arrival-rate',
      exec: 'fast_query',
      rate: {{ fast_rps }},
      timeUnit: '1s',
      duration: '24h',
      preAllocatedVUs: {{ fastMaxVUs }},
      maxVUs: {{ fastMaxVUs }},
    },
{% endif %}
{% if slow_rps > 0 %}
    slow_queries: {
      executor: 'constant-arrival-rate',
      exec: 'slow_query',
      rate: {{ slow_rps }},
      timeUnit: '1s',
      duration: '24h',
      preAllocatedVUs: {{ slowMaxVUs }},
      maxVUs: {{ slowMaxVUs }},
    },
{% endif %}
{% else %}
    main: {
      executor: 'constant-arrival-rate',
      rate: {{ fast_rps }},
      timeUnit: '1s',
      duration: '24h',
      preAllocatedVUs: {{ maxVUs }},
      maxVUs: {{ maxVUs }},
    },
{% endif %}
  },
  insecureSkipTLSVerify: true,
};

export function setup() {
  const configClient = new remote.Client({ url: METRICS_URL });
  configClient.store([
    remote.Timeseries(
      {
        __name__: 'breaking_bench_config',
        mode: '{{ mode }}',
        metric_name: '{{ metric_name }}',
        write_url: WRITE_URL,
        select_url: SELECT_URL,
        fast_rps: '{{ fast_rps }}',
{% if mode == 'select' %}
        slow_rps: '{{ slow_rps }}',
{% endif %}
        num_metrics: '{{ num_metrics }}',
        num_labels: '{{ num_labels }}',
      },
      [remote.Sample(1, Date.now())],
    ),
  ]);
}

{% if mode == 'insert' %}
const client = new remote.Client({ url: WRITE_URL });

export default function () {
  const metricIdx = faker.numbers.intRange(0, {{ num_metrics - 1 }});
  const res = client.store([
    remote.Timeseries(
      {
        __name__: `{{ metric_name }}_${metricIdx}`,
        foo: `bar`,
        random: faker.strings.letterN(8),
{% for i in range(num_labels) %}
        label_{{ i }}: faker.strings.letterN(8),
{% endfor %}
      },
      [remote.Sample(faker.numbers.intRange(0, 10), Date.now())],
    ),
  ]);
  check(res, { 'insert status is 204': (r) => r.status === 204 });
}
{% else %}
export function fast_query() {
  const metricIdx = faker.numbers.intRange(0, {{ num_metrics - 1 }});
  // Shift the window past VM's cacheTimestampOffset (default 5m) so the full
  // response cache is used. Align end to step boundary for stable cache keys.
  const step = 15;
  const cacheOffset = 5 * 60; // VM default search.cacheTimestampOffset
  const now = Math.floor(Date.now() / 1000);
  const end = Math.floor((now - cacheOffset) / step) * step;
  const start = end - 5 * 60;
  const res = http.post(
    SELECT_URL,
    { query: `{{ metric_name }}_${metricIdx}\{foo="bar"\}`, start: start, end: end, step: `${step}s` },
    { responseType: 'none' },
  );
  check(res, { 'query status is 200': (r) => r.status === 200 });
}

export function slow_query() {
  const now = Date.now();
  // 10 minutes ago
  const start = Math.floor((now - 10 * 60 * 1000) / 1000);
  const end = Math.floor(now / 1000);
  const metricIdx = faker.numbers.intRange(0, {{ num_metrics - 1 }});
  const res = http.post(
    SELECT_URL,
    { query: `{{ metric_name }}_${metricIdx}\{foo="bar"\}`, start: start, end: end, step: '15s' },
    { responseType: 'none' },
  );
  check(res, { 'query status is 200': (r) => r.status === 200 });
}
{% endif %}
